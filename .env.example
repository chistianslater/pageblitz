# Pageblitz Environment Variables

# Database
DATABASE_URL=mysql://username:password@host:port/database

# Authentication
JWT_SECRET=your-jwt-secret-here
VITE_APP_ID=https://your-domain.com
OAUTH_SERVER_URL=https://your-oauth-server.com
OWNER_OPEN_ID=your-admin-open-id

# AI/LLM APIs
BUILT_IN_FORGE_API_URL=https://api.built-in-forge.com
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Pageblitz <noreply@your-domain.com>

# Stripe (for payments) - Get keys from Stripe Dashboard
# See documentation at https://docs.stripe.com/keys

# Optional: Google Places API (for GMB integration)
GOOGLE_PLACES_API_KEY=your-google-places-api-key
